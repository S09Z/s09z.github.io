            </p>
          </div>

          <div class="contact-items">
            <a href="mailto:i.boonyarakthunya@gmail.com" class="contact-item">
              <span class="contact-item-label">// email</span>
              <span class="contact-item-val">i.boonyarakthunya@gmail.com</span>
            </a>
            <a href="tel:+66972471491" class="contact-item">
              <span class="contact-item-label">// phone</span>
              <span class="contact-item-val">+66 97 247 1491</span>
            </a>
            <a href="https://github.com/S09Z" target="_blank" rel="noopener" class="contact-item">
              <span class="contact-item-label">// github</span>
              <span class="contact-item-val">github.com/S09Z</span>
            </a>
            <a href="https://www.linkedin.com/in/ittichaib/" target="_blank" rel="noopener" class="contact-item">
              <span class="contact-item-label">// linkedin</span>
