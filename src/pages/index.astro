  <script>
    /* Live clock */
    const clockEl = document.getElementById('clock');
    setInterval(() => {
      if (!clockEl) return;
      const d = new Date();
      const opts: Intl.DateTimeFormatOptions = {
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        hour12: false, timeZone: 'Asia/Bangkok',
      };
      clockEl.textContent = d.toLocaleTimeString('en-GB', opts) + ' ICT';
    }, 1000);

    /* Custom cursor: ring (spring) + dot (instant) */
    const ring = document.getElementById('cring')!;
    const dot  = document.getElementById('cdot')!;
    let mx = window.innerWidth / 2, my = window.innerHeight / 2;
    let rx = mx, ry = my;

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX; my = e.clientY;
      dot.style.transform = `translate(${mx}px,${my}px) translate(-50%,-50%)`;
    });

    /* Grow ring on interactive elements */
    document.querySelectorAll('a, button').forEach((el) => {
      el.addEventListener('mouseenter', () => ring.classList.add('hover'));
      el.addEventListener('mouseleave', () => ring.classList.remove('hover'));
    });

    /* Liquid text distortion on [data-liq] elements */
    document.querySelectorAll('[data-liq]').forEach((el) => {
      const walk = (node: Node) => {
        if (node.nodeType === 3) {
          /* Collapse HTML indentation whitespace (newlines + multi-space)
             into a single space, then skip purely-whitespace nodes. */
          const text = (node.textContent ?? '')
            .replace(/[\n\r\t]+/g, ' ')
            .replace(/ {2,}/g, ' ');
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          for (const c of [...text]) {
            if (c === ' ') {
              frag.appendChild(document.createTextNode(' '));
            } else {
              const s = document.createElement('span');
              s.className = 'ch';
              s.textContent = c;
              frag.appendChild(s);
            }
          }
          node.parentNode!.replaceChild(frag, node);
        } else if (node.nodeType === 1) {
          [...node.childNodes].forEach(walk);
        }
      };
      walk(el);
    });

    const chars = document.querySelectorAll<HTMLElement>('.ch');

    function liquify() {
      const R = 140;
      chars.forEach((c) => {
        const r = c.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top  + r.height / 2;
        const dx = cx - mx, dy = cy - my;
        const d = Math.hypot(dx, dy);
        if (d < R) {
          const f   = 1 - d / R;
          const ang = Math.atan2(dy, dx);
          const ox  = Math.cos(ang) * 18 * f;
          const oy  = Math.sin(ang) * 18 * f;
          const sc  = 1 + f * 0.5;
          const rot = (dx / R) * 8 * f;
          c.style.transform = `translate(${ox}px,${oy}px) scale(${sc}) rotate(${rot}deg)`;
          c.style.color = `oklch(${0.74 + f * 0.1} 0.18 295)`;
        } else if (c.style.transform) {
          c.style.transform = '';
          c.style.color = '';
        }
      });
    }

    function loop() {
      rx += (mx - rx) * 0.18;
      ry += (my - ry) * 0.18;
      ring.style.transform = `translate(${rx}px,${ry}px) translate(-50%,-50%)`;
      liquify();
      requestAnimationFrame(loop);
    }
    loop();
  </script>

</Layout>
