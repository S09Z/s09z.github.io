---
import Layout from '../layouts/Layout.astro';
import HackedTextTitle from '../components/HackedTextTitle.astro';
import StarField from '../components/StarField.astro';

const technologyList = [
  { name: 'NextJS',      icon: 'devicon-nextjs-original' },
  { name: 'VueJS',       icon: 'devicon-vuejs-plain' },
  { name: 'NuxtJS',      icon: 'devicon-nuxtjs-plain' },
  { name: 'ReactJS',     icon: 'devicon-react-original' },
  { name: 'Express',     icon: 'devicon-express-original' },
  { name: 'NodeJS',      icon: 'devicon-nodejs-plain' },
  { name: 'CSS',         icon: 'devicon-css3-plain' },
  { name: 'HTML',        icon: 'devicon-html5-plain' },
  { name: 'Javascript',  icon: 'devicon-javascript-plain' },
  { name: 'Typescript',  icon: 'devicon-typescript-plain' },
  { name: 'TailwindCSS', icon: 'devicon-tailwindcss-plain' },
  { name: 'Bootstrap',   icon: 'devicon-bootstrap-plain' },
  { name: 'PHP',         icon: 'devicon-php-plain' },
  { name: 'Laravel',     icon: 'devicon-laravel-plain' },
  { name: 'Docker',      icon: 'devicon-docker-plain' },
  { name: 'Git',         icon: 'devicon-git-plain' },
  { name: 'Elixir',      icon: 'devicon-elixir-plain' },
  { name: 'Go',          icon: 'devicon-go-original-wordmark' },
  { name: 'MySQL',       icon: 'devicon-mysql-plain' },
  { name: 'PostgreSQL',  icon: 'devicon-postgresql-plain' },
  { name: 'Jest',        icon: 'devicon-jest-plain' },
];

const bio = `Sawad-dee I'm Oat. I'm a Mid-Level Full Stack Developer. You can find me hacking away with React, NextJS, TypeScript, TailwindCSS or anything related on the front-end & back-end. I have a good eye for UX & UI and web design. I am currently learning Golang and Python, and researching on Flutter and Elixir. Also looking further to improve my DevOps, Cloud Engineer and Data Engineer skills in the future.`;

const overview = `I have been working in web development for over 5 years, proficient in both JS and PHP. I also have experience developing and deploying enterprise-level web projects like document digital signature management, business process management, and report dashboards. I like to always improve my work — a self-motivated creative thinker with a high passion for designing, adaptation and learning new things.`;
---

<Layout>
  <!-- Page wrapper — StarField targets this -->
  <main class="page relative flex flex-col min-h-screen overflow-hidden">

    <!-- Faint neon background image -->
    <div class="bgNeonGithub absolute w-full pointer-events-none"></div>

    <!-- Centred content column -->
    <div class="relative z-10 max-w-5xl w-full mx-auto px-4 py-28">

      <!-- Neon card -->
      <div class="neon p-8 md:p-16 flex flex-col gap-8">

        <!-- ── Header ─────────────────────────────────── -->
        <div class="flex flex-col items-center gap-3">
          <p class="text-sm text-gray-400 tracking-widest uppercase">Full Stack Developer</p>

          <HackedTextTitle />

          <!-- Contact row -->
          <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 mt-1">

            <a href="tel:+66972471491" class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              (+66) 97-247-1491
            </a>

            <span class="contact-divider"></span>

            <a href="mailto:i.boonyarakthunya@gmail.com" class="contact-link">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              i.boonyarakthunya@gmail.com
            </a>

            <span class="contact-divider"></span>

            <a
              href="https://www.google.com/maps/place/Bangkok"
              target="_blank" rel="noopener noreferrer"
              class="contact-link"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Bangkok / Thailand
            </a>

            <span class="contact-divider"></span>

            <a href="https://github.com/S09Z" target="_blank" rel="noopener noreferrer" class="contact-link">
              <i class="devicon-github-original text-base"></i>
              S09Z
            </a>

            <span class="contact-divider"></span>

            <a href="https://www.linkedin.com/in/ittichaib/" target="_blank" rel="noopener noreferrer" class="contact-link">
              <i class="devicon-linkedin-plain text-base"></i>
              ittichaib
            </a>

          </div>
        </div>

        <!-- ── Tech chips ──────────────────────────────── -->
        <div class="flex flex-wrap gap-2">
          {technologyList.map((tag) => (
            <span class="tech-chip">
              <i class={`${tag.icon} text-base leading-none`}></i>
              {tag.name}
            </span>
          ))}
        </div>

        <!-- ── Bio ────────────────────────────────────── -->
        <div class="section-row">
          <div class="section-bar-wrap">
            <div class="section-bar"></div>
            <span class="section-label">Hi !</span>
          </div>
          <p class="flex-1 text-sm leading-relaxed">{bio}</p>
        </div>

        <!-- ── Overview ───────────────────────────────── -->
        <div class="section-row">
          <div class="section-bar-wrap">
            <div class="section-bar"></div>
            <span class="section-label">Overview</span>
          </div>
          <p class="flex-1 text-sm leading-relaxed">{overview}</p>
        </div>

        <!-- ── Signature ──────────────────────────────── -->
        <div class="relative w-full h-36 mt-2">
          <img
            src="/images/neon-signature.png"
            alt="Ittichai Boonyarakthunya signature"
            class="absolute inset-0 w-full h-full object-contain"
          />
        </div>

      </div><!-- /neon card -->
    </div><!-- /container -->

    <!-- Animated star field -->
    <StarField />

  </main>

  <!-- Cursor flashlight -->
  <script>
    const update = (x: number, y: number) => {
      document.documentElement.style.setProperty('--cursorX', `${x}px`);
      document.documentElement.style.setProperty('--cursorY', `${y}px`);
    };
    document.addEventListener('mousemove', (e) => update(e.clientX, e.clientY));
    document.addEventListener('touchmove', (e) =>
      update(e.touches[0]!.clientX, e.touches[0]!.clientY),
    );
  </script>
</Layout>
