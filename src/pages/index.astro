---
import Layout from '../layouts/Layout.astro';

const techStack = [
  'TypeScript', 'JavaScript', 'PHP', 'Go', 'Elixir', 'Python',
  'React', 'Next.js', 'Vue.js', 'Nuxt', 'Tailwind', 'Bootstrap',
  'HTML5', 'CSS3', 'Node.js', 'Express', 'Laravel', 'NestJS',
  'PostgreSQL', 'MySQL', 'Docker', 'Git', 'Jest', 'Linux',
];

const projects = [
  {
    tag: 'enterprise',
    period: '2024 — now',
    role: 'lead front-end · ongoing',
    letter: 'S·',
    accent: '#a78bfa',
    title: 'Digital Signature Platform',
    desc: 'End-to-end document signing for thousands of corporate users. Led the Next 15 + RSC migration, modernised the canvas-based signing flow, owned the design-system rewrite.',
    stack: ['Next.js', 'TS', 'Tailwind', 'Node', 'PostgreSQL'],
  },
  {
    tag: 'BPM',
    period: '2022 — 2024',
    role: 'full-stack · shipped',
    letter: 'B·',
    accent: '#60a5fa',
    title: 'Workflow Engine + Dashboards',
    desc: 'Role-based document routing for an in-house BPM platform. Cut average approval time from days to hours. Owned the Vue 3 component library & the reporting dashboards.',
    stack: ['Vue 3', 'Nuxt', 'Laravel', 'PHP', 'MySQL'],
  },
  {
    tag: 'freelance',
    period: '2020 — 2022',
    role: 'solo build',
    letter: 'R·',
    accent: '#f97316',
    title: 'Reporting Dashboard Suite',
    desc: 'Custom analytics dashboards for several agency clients. Real-time data viz with charts, drilldowns, exportable reports. Delivered solo on short timelines.',
    stack: ['React', 'Express', 'D3', 'Bootstrap'],
  },
];

const workHistory = [
  {
    period: '2024 — now',
    active: true,
    role: 'Full-stack engineer',
    company: 'Enterprise baan · Bangkok',
    desc: 'Lead front-end on a digital signature platform serving thousands of documents monthly. Drive the migration to Next 15 + RSC, owning JS for a 6-engineer team.',
    stack: ['Next.js', 'TypeScript', 'React', 'Node.js', 'PostgreSQL'],
  },
  {
    period: '2022 — 2024',
    active: false,
    role: 'Web developer',
    company: 'Business process · Bangkok',
    desc: 'Built BPM workflow engine and dashboard suite. Implemented role-based document routing, cut average approval time from days to hours.',
    stack: ['Vue 3', 'Nuxt', 'Laravel', 'PHP', 'MySQL'],
  },
  {
    period: '2020 — 2022',
    active: false,
    role: 'Junior developer',
    company: 'Agency + Freelance · Bangkok',
    desc: 'Shipped reporting dashboards, e-commerce front-ends, WordPress customisations. Learned the difference between code that works and code that ships.',
    stack: ['React', 'Express', 'Bootstrap', 'PHP'],
  },
  {
    period: '2019',
    active: false,
    role: 'First repo, first deploy',
    company: 'Intern · Bangkok',
    desc: 'CS internship — wrote the first commit that went to production. Hooked.',
    stack: ['HTML', 'CSS', 'JavaScript', 'PHP'],
  },
];
---

<Layout title="Ittichai Boonyarakthunya · Software Engineer · Bangkok">

